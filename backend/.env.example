PORT=3001
NODE_ENV=development

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 국토부 실거래가 (data.go.kr - 무료)
MOLIT_API_KEY=your_molit_api_key

# 카카오 REST API (developers.kakao.com - 무료 월 30만건)
KAKAO_REST_API_KEY=your_kakao_rest_key

# 네이버 지도 NCP Web Dynamic Map client ID (console.ncloud.com - 월 100만건 무료)
# public — 설정 시 frontend 가 네이버 지도 SDK 로드, 미설정 시 Leaflet/OSM fallback (server.js 가 /api/health 로 노출).
NAVER_MAPS_CLIENT_ID=your_naver_client_id

# 보안
JWT_SECRET=myhomelog_secret_key_min_32_chars_change_this
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://myhomelog.vercel.app

# 캐시
CACHE_TTL_SECONDS=3600
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Supabase (supabase.com - 프리티어)
# URL/Publishable 은 클라이언트 노출 OK. SERVICE_ROLE 는 절대 프론트 노출 금지.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Drizzle/직접 쿼리용 Postgres connection string (Dashboard > Settings > Database)
# pooler 엔드포인트 권장 (서버리스 호환)
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# Toss Payments (payments.tosspayments.com)
# 서버 전용 시크릿 키 — 절대 프론트에 노출 금지. test_sk_* / live_sk_* 형식.
# 미설정 시 /api/billing/confirm 은 501 반환.
TOSS_SECRET_KEY=test_sk_xxxxx
# (옵션) 클라이언트 키는 프론트에 <meta> 로 주입 — live 환경에서 Toss Widget SDK 가 사용
TOSS_CLIENT_KEY=test_ck_xxxxx
# (옵션) Toss 대시보드 webhook 정적 헤더 — 설정 시 /api/billing/webhook 이 X-Webhook-Secret 헤더 일치 검증 (이중 방어).
# 미설정 시 webhook 은 Toss REST 재조회(/v1/payments/{key}) 만으로 검증. billing.js 가 참조.
TOSS_WEBHOOK_SECRET=

# 고객 지원 / GDPR·PIPA 이의 제기 접수 이메일 (자동화결정 설명 응답에 포함)
# 미설정 시 기본값 privacy@myhomelog.app 사용.
SUPPORT_EMAIL=privacy@myhomelog.app

# AI 월간 사용자 예산 (USD) — 초과 시 callAI 차단 (BudgetExceededError → 429)
# 기본 $3. 유료 플랜 도입 시 사용자별 이 값 오버라이드 가능.
USER_MONTHLY_BUDGET_USD=3

# 전역 AI 지출 상한 (kill-switch) — 모든 AI 호출(익명+로그인+cron) 합산이 초과하면 신규 호출 차단.
# 사용자 수·어뷰징과 무관하게 총 Anthropic 비용 천장 보장. 캐시 히트(무료)는 영향 없음.
# 미설정 시 기본 일 $5 / 월 $30. 더 낮추려면 값 조정 (예: 월 $10). 0 이하면 비활성(무제한).
GLOBAL_AI_DAILY_USD=5
GLOBAL_AI_MONTHLY_USD=30

# 크론 인증용 시크릿 — Vercel Cron 헤더 "Authorization: Bearer ${CRON_SECRET}" 로 호출
# 미설정 시 /api/cron/* 는 403.
CRON_SECRET=change_this_cron_secret

# ── ENV-EXAMPLE-SYNC-2026-07-17 (Sprint WWWWW): 코드에서 실제 사용하지만 예시에 누락됐던 변수 추가.
#    전부 optional(미설정 시 graceful degrade) — 로컬 구동은 되지만 해당 기능이 조용히 비활성화됨.
# 에러 모니터링 (sentry.io) — 미설정 시 Sentry no-op. sentry.js 가 참조.
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# Upstash Redis (upstash.com - 프리티어) — 레이트리밋·인스턴스 간 캐시 공유. 미설정 시 in-memory fallback(단일 인스턴스). redis.js 참조.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# 한국은행 ECOS 금리 (ecos.bok.or.kr - 무료) — 미설정 시 시중금리 힌트/데이터 시황 생략. ecosService.js 참조.
ECOS_API_KEY=
# KOSIS 미분양 통계 (kosis.kr openapi - 무료) — 미설정 시 미분양 지표 생략. kosisService.js 참조.
KOSIS_API_KEY=
# 국가법령정보 OPEN API OC (law.go.kr - 무료) — 미설정 시 법령 원문 조회 생략. legalService.js 참조.
LAW_GO_KR_OC=
# NEIS 학교알리미 (open.neis.go.kr - 무료, optional) — 미설정 시 sample 키 사용. schoolNeisService.js 참조.
NEIS_API_KEY=
# 네이버 검색 API (developers.naver.com - 무료) — 미설정 시 뉴스는 Google News RSS fallback. news.js 참조.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 관리자 이메일 화이트리스트 (쉼표 구분) — 검색·AI 무제한·admin 라우트 접근. planService.js 참조.
ADMIN_EMAILS=
# /api/health 상세 조회 인증 키 (optional) — 설정 시 X-Health-Key 헤더 일치 요구. server.js 참조.
HEALTH_API_KEY=
