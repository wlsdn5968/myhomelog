{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "includeFiles": "frontend/index.html",
      "excludeFiles": "{**/*.{test,spec}.js,**/{test,tests,__tests__,docs,coverage}/**,**/*.{md,map},**/.env*,**/.{git,github,vscode,idea}/**,supabase/**,scripts/**,frontend/{billing,privacy,terms,refund}.html,**/node_modules/{typescript,@types,.bin}/**}"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/share(.*)", "dest": "/api/index.js" },
    { "src": "/billing(/.*)?", "dest": "/frontend/billing.html" },
    { "src": "/privacy(\\.html)?", "dest": "/frontend/privacy.html" },
    { "src": "/terms(\\.html)?", "dest": "/frontend/terms.html" },
    { "src": "/refund(\\.html)?", "dest": "/frontend/refund.html" },
    { "src": "/sitemap\\.xml", "dest": "/frontend/sitemap.xml", "headers": { "Content-Type": "application/xml" } },
    { "src": "/robots\\.txt", "dest": "/frontend/robots.txt", "headers": { "Content-Type": "text/plain" } },
    { "src": "/manifest\\.json", "dest": "/frontend/manifest.json", "headers": { "Content-Type": "application/manifest+json" } },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/retention",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/molit-ingest",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/apt-master-sync",
      "schedule": "0 20 * * 1"
    },
    {
      "path": "/api/cron/regulations-check",
      "schedule": "0 21 * * 1"
    },
    {
      "path": "/api/cron/audit-prune",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/geocache-backfill",
      "schedule": "0 * * * *"
    }
  ]
}
